<Window x:Class="SonarLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SonarLite"
        xmlns:models="clr-namespace:SonarLite.Models"
        mc:Ignorable="d"
        Title="SonarLite" Height="780" Width="960" MinWidth="780" MinHeight="620"
        Background="#16161C" Foreground="#F2F2F5" FontFamily="Segoe UI"
        Icon="SonarLite.ico"
        StateChanged="Window_StateChanged" Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#16161C"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#1E1E26"/>
        <SolidColorBrush x:Key="CardBrush" Color="#262630"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#2E2E3A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF7A45"/>
        <SolidColorBrush x:Key="AccentDimBrush" Color="#7A3D24"/>
        <SolidColorBrush x:Key="TrackBrush" Color="#3A3A46"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F2F2F5"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="#9A9AA8"/>
        <SolidColorBrush x:Key="EdgeBrush" Color="#34343F"/>

        <!-- Per-channel identity colours, in the spirit of Sonar's Game/Chat/Media buses. -->
        <SolidColorBrush x:Key="GameBrush" Color="#4ADE80"/>
        <SolidColorBrush x:Key="ChatBrush" Color="#60A5FA"/>
        <SolidColorBrush x:Key="MediaBrush" Color="#F472B6"/>

        <local:PeakToScaleConverter x:Key="PeakToScale"/>
        <local:BoolToCollapsedConverter x:Key="BoolToCollapsed"/>
        <local:ClassToBrushConverter x:Key="ClassToBrush"
                                     Game="#4ADE80" Chat="#60A5FA" Media="#F472B6"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style x:Key="SThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="Dot" Width="13" Height="13" Fill="#E8E8EE"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Dot" Property="Fill" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Dot" Property="Fill" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical-bar grip (not a dot): reads as a position marker on a spectrum, used only by the ChatMix slider. -->
        <Style x:Key="MixThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bar" Width="9" Height="24" CornerRadius="3" Background="#E8E8EE">
                            <Rectangle Width="1.5" Height="10" Fill="#9A9AA8" RadiusX="1" RadiusY="1"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bar" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Bar" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The filled part takes its colour from the Slider's Foreground, so each channel strip
             can paint its own fader without needing a separate template. -->
        <Style x:Key="HFill" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="4" CornerRadius="2"
                                Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Slider}}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HEmpty" TargetType="RepeatButton" BasedOn="{StaticResource HFill}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="4" CornerRadius="2" Background="{StaticResource TrackBrush}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Band fills follow the EQ list's Foreground, which the code-behind repaints with the
             colour of whichever profile is being edited. Bound to the ItemsControl rather than the
             Slider because Slider.Foreground would otherwise inherit the window's white text brush. -->
        <Style x:Key="VFill" TargetType="RepeatButton" BasedOn="{StaticResource HFill}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Width="4" CornerRadius="2"
                                Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="VEmpty" TargetType="RepeatButton" BasedOn="{StaticResource HFill}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Width="4" CornerRadius="2" Background="{StaticResource TrackBrush}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HSlider" TargetType="Slider">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent" MinHeight="18">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource HFill}" Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource HEmpty}" Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MixSlider" TargetType="Slider">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent" MinHeight="24">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource HFill}" Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource HEmpty}" Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource MixThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VSlider" TargetType="Slider">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent" MinWidth="18">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource VFill}" Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource VEmpty}" Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{StaticResource TrackBrush}" CornerRadius="3"/>
                            <Border x:Name="PART_Indicator" Background="{StaticResource AccentBrush}" CornerRadius="3" HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="Box" Width="16" Height="16" CornerRadius="4"
                                    Background="{StaticResource CardBrush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Path x:Name="Check" Data="M2,8 L6,12 13,3" Stroke="White" StrokeThickness="2" Visibility="Collapsed"
                                      Stretch="Uniform" Margin="2"/>
                            </Border>
                            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Padding="10,7" Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDimBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                                                BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1">
                                            <Path Data="M0,0 L8,0 4,5 Z" Fill="{StaticResource TextDimBrush}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="10,0,26,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False">
                                <Border MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260" Margin="0,4,0,0"
                                        Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource EdgeBrush}"
                                        BorderThickness="1" CornerRadius="8">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Selected profile lights up in its own channel colour (set per-button via Background),
             so the EQ section always tells you which bus you are editing. -->
        <Style x:Key="ProfileToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="11,7"
                                BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Setter Property="Foreground" Value="#12121A"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MuteToggle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" CornerRadius="4" Padding="4">
                            <TextBlock x:Name="Glyph" Text="&#x1F50A;" FontSize="13"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Glyph" Property="Text" Value="&#x1F507;"/>
                                <Setter TargetName="Glyph" Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22"/>
                            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="8,16,8,-8" To="8,4,8,4"
                                                Duration="0:0:0.22" DecelerationRatio="0.8"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Channel strip header: identity, live meter, fader and mute for a whole bus. -->
        <DataTemplate x:Key="BusHeader" DataType="{x:Type models:BusChannel}">
            <StackPanel Margin="12,10,12,6">
                <DockPanel Margin="0,0,0,6">
                    <Ellipse Width="8" Height="8" Fill="{Binding Accent}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding VolumePercent, StringFormat={}{0}%}"
                               Foreground="{StaticResource TextDimBrush}" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                </DockPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Muting drains the colour out of the meter and fader, but never out of the
                         mute button itself — that is the control you need to find to undo it. -->
                    <StackPanel Grid.Column="0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                        <Setter Property="Opacity" Value="0.3"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Border Height="3" CornerRadius="1.5" Background="{StaticResource TrackBrush}" Margin="0,0,0,8">
                            <Border Background="{Binding Accent}" CornerRadius="1.5"
                                    HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="{Binding Peak, Converter={StaticResource PeakToScale}}"/>
                                </Border.RenderTransform>
                            </Border>
                        </Border>

                        <Slider Style="{StaticResource HSlider}" Minimum="0" Maximum="100"
                                Foreground="{Binding Accent}"
                                Value="{Binding VolumePercent, Mode=TwoWay}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ToggleButton Grid.Column="1" Style="{StaticResource MuteToggle}" Margin="8,0,0,0"
                                  IsChecked="{Binding IsMuted, Mode=TwoWay}" VerticalAlignment="Bottom"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- Shown over an empty channel; doubles as a hint that tiles can be dragged between buses. -->
        <Style x:Key="EmptyHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,26,0,0"/>
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Text" Value="Drag apps here"/>
        </Style>

        <DataTemplate DataType="{x:Type models:AppSession}">
            <Border CornerRadius="8" Padding="10,8" BorderThickness="1" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <Image Source="{Binding Icon}" Width="18" Height="18" Margin="0,0,7,0" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding VolumePercent, StringFormat={}{0}%}"
                                   Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    </DockPanel>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Style="{StaticResource HSlider}" Minimum="0" Maximum="100"
                                Foreground="{Binding Classification, Converter={StaticResource ClassToBrush}}"
                                Value="{Binding VolumePercent, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <ToggleButton Grid.Column="1" Style="{StaticResource MuteToggle}" Margin="6,0,0,0"
                                      IsChecked="{Binding IsMuted, Mode=TwoWay}" VerticalAlignment="Center"/>
                    </Grid>
                    <!-- Live level meter, tinted with the colour of the bus this app sits on. -->
                    <Border Grid.Row="2" Height="3" CornerRadius="1.5" Margin="0,5,26,0"
                            Background="{StaticResource TrackBrush}">
                        <Border Background="{Binding Classification, Converter={StaticResource ClassToBrush}}"
                                CornerRadius="1.5" HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="{Binding Peak, Converter={StaticResource PeakToScale}}"/>
                            </Border.RenderTransform>
                        </Border>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: title + device pickers -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Image x:Name="HeaderIcon" Width="24" Height="24" Margin="0,0,9,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="SonarLite" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                <TextBlock Text="PLAYBACK" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="2,0,0,3"/>
                <ComboBox x:Name="PlaybackCombo" DisplayMemberPath="Name" SelectionChanged="PlaybackCombo_SelectionChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="MICROPHONE" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="2,0,0,3"/>
                <ComboBox x:Name="RecordingCombo" DisplayMemberPath="Name" SelectionChanged="RecordingCombo_SelectionChanged"/>
            </StackPanel>
        </Grid>

        <!-- ChatMix dial readout. Shows where the base station's dial IS; it cannot move it. The
             dial is a physical encoder, so this is a meter, not a control (hence IsHitTestVisible
             below). Collapsed until the dial is actually being read: with no hardware there is no
             honest reading to show, and an idle bar just looks like a broken slider. -->
        <Border x:Name="ChatMixCard" Grid.Row="1" Style="{StaticResource Card}" Padding="14,10"
                Margin="0,0,0,12" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ChatMix" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>
                <TextBlock Grid.Column="1" Text="CHAT" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,0" HorizontalAlignment="Right"/>
                <Slider Grid.Column="2" x:Name="ChatMixSlider" Style="{StaticResource MixSlider}" Minimum="0" Maximum="100"
                        Value="50" IsHitTestVisible="False" VerticalAlignment="Center" Height="24"/>
                <TextBlock Grid.Column="3" Text="GAME + MEDIA" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- App tiles in category columns -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" x:Name="GameCol" Style="{StaticResource Card}" Margin="0,0,5,0">
                <DockPanel>
                    <ContentControl DockPanel.Dock="Top" x:Name="GameHeader"
                                    ContentTemplate="{StaticResource BusHeader}"/>
                    <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource EdgeBrush}" Margin="12,0,12,4"/>
                    <Grid>
                        <ListBox x:Name="GameList" Background="Transparent" BorderThickness="0" AllowDrop="True"
                                 ItemContainerStyle="{StaticResource TileItem}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 PreviewMouseLeftButtonDown="Tile_MouseDown" PreviewMouseMove="Tile_MouseMove"
                                 Drop="Column_Drop" DragOver="Column_DragOver" DragEnter="Column_DragEnter" DragLeave="Column_DragLeave"/>
                        <TextBlock Style="{StaticResource EmptyHint}"
                                   Visibility="{Binding HasItems, ElementName=GameList, Converter={StaticResource BoolToCollapsed}}"/>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" x:Name="ChatCol" Style="{StaticResource Card}" Margin="5,0,5,0">
                <DockPanel>
                    <ContentControl DockPanel.Dock="Top" x:Name="ChatHeader"
                                    ContentTemplate="{StaticResource BusHeader}"/>
                    <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource EdgeBrush}" Margin="12,0,12,4"/>
                    <Grid>
                        <ListBox x:Name="ChatList" Background="Transparent" BorderThickness="0" AllowDrop="True"
                                 ItemContainerStyle="{StaticResource TileItem}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 PreviewMouseLeftButtonDown="Tile_MouseDown" PreviewMouseMove="Tile_MouseMove"
                                 Drop="Column_Drop" DragOver="Column_DragOver" DragEnter="Column_DragEnter" DragLeave="Column_DragLeave"/>
                        <TextBlock Style="{StaticResource EmptyHint}"
                                   Visibility="{Binding HasItems, ElementName=ChatList, Converter={StaticResource BoolToCollapsed}}"/>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" x:Name="MediaCol" Style="{StaticResource Card}" Margin="5,0,0,0">
                <DockPanel>
                    <ContentControl DockPanel.Dock="Top" x:Name="MediaHeader"
                                    ContentTemplate="{StaticResource BusHeader}"/>
                    <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource EdgeBrush}" Margin="12,0,12,4"/>
                    <Grid>
                        <ListBox x:Name="MediaList" Background="Transparent" BorderThickness="0" AllowDrop="True"
                                 ItemContainerStyle="{StaticResource TileItem}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 PreviewMouseLeftButtonDown="Tile_MouseDown" PreviewMouseMove="Tile_MouseMove"
                                 Drop="Column_Drop" DragOver="Column_DragOver" DragEnter="Column_DragEnter" DragLeave="Column_DragLeave"/>
                        <TextBlock Style="{StaticResource EmptyHint}"
                                   Visibility="{Binding HasItems, ElementName=MediaList, Converter={StaticResource BoolToCollapsed}}"/>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Equalizer -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="14,12" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="232"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="EQUALIZER" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <ToggleButton x:Name="EqProfileGame" Style="{StaticResource ProfileToggle}" Content="Game"
                                      Background="{StaticResource GameBrush}"
                                      Checked="EqProfile_Checked" Click="EqProfile_Click" Margin="0,0,4,0"/>
                        <ToggleButton x:Name="EqProfileChat" Style="{StaticResource ProfileToggle}" Content="Chat"
                                      Background="{StaticResource ChatBrush}"
                                      Checked="EqProfile_Checked" Click="EqProfile_Click" Margin="0,0,4,0"/>
                        <ToggleButton x:Name="EqProfileMedia" Style="{StaticResource ProfileToggle}" Content="Media"
                                      Background="{StaticResource MediaBrush}"
                                      Checked="EqProfile_Checked" Click="EqProfile_Click"/>
                    </StackPanel>
                    <TextBlock Text="Preset" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="2,0,0,3"/>
                    <ComboBox x:Name="EqPresetCombo" DisplayMemberPath="Name" SelectionChanged="EqPresetCombo_SelectionChanged" Margin="0,0,0,10"/>
                    <CheckBox x:Name="EqEnabledCheck" Content="EQ enabled" Checked="EqEnabledCheck_Changed" Unchecked="EqEnabledCheck_Changed"/>
                    <TextBlock x:Name="EqStatusLabel" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <ItemsControl Grid.Column="1" x:Name="EqBandList" HorizontalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:EqBand}">
                            <StackPanel Width="56" Margin="2,0">
                                <Slider Style="{StaticResource VSlider}" Height="104" Minimum="-12" Maximum="12"
                                        Value="{Binding GainDb, Mode=TwoWay}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Label}" HorizontalAlignment="Center" FontSize="10" Margin="0,4,0,0"
                                           Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="{Binding GainDb, StringFormat={}{0:0.0}}" HorizontalAlignment="Center" FontSize="9"
                                           Foreground="{StaticResource TextDimBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Grid Grid.Row="4" Margin="2,10,2,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusLabel" FontSize="11" Foreground="{StaticResource TextDimBrush}"
                       Text="Waiting for headset dial..." VerticalAlignment="Center"/>
            <CheckBox Grid.Column="1" x:Name="AutostartCheck" Content="Start with Windows"
                      Checked="AutostartCheck_Changed" Unchecked="AutostartCheck_Changed"/>
        </Grid>
    </Grid>
</Window>
